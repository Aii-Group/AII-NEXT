{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "useTabs": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 140,
  "singleAttributePerLine": true,
  "jsxSingleQuote": true,
  "endOfLine": "lf",
  "bracketSpacing": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "sortPackageJson": false,
  "sortTailwindcss": {
    "stylesheet": "./src/index.css"
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "dist-ssr/",
    ".tanstack/",
    "src/routeTree.gen.ts",
    "src/api/sysmgnt/",
    "pnpm-lock.yaml",
    "skills-lock.json",
    ".agents/",
    ".claude/"
  ]
}
