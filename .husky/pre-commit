#!/bin/sh

staged=$(git diff --cached --name-only --diff-filter=ACMR)

if echo "$staged" | grep -E '(^|/)\.env$|(^|/)\.env\.local$|(^|/)\.env\.[^/]+\.local$|credentials\.json|\.pem$|id_rsa' >/dev/null 2>&1; then
  echo "❌ 禁止提交敏感文件（.env、credentials、私钥等）"
  echo "$staged" | grep -E '(^|/)\.env$|(^|/)\.env\.local$|(^|/)\.env\.[^/]+\.local$|credentials\.json|\.pem$|id_rsa' || true
  exit 1
fi

pnpm exec lint-staged
