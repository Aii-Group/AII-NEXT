#!/bin/sh

staged=$(git diff --cached --name-only --diff-filter=ACMR)

if echo "$staged" | grep -E '(^|/)\.env$|(^|/)\.env\.local$|(^|/)\.env\.[^/]+\.local$|credentials\.json|\.pem$|id_rsa' >/dev/null 2>&1; then
  echo "❌ 禁止提交敏感文件（.env、credentials、私钥等）"
  echo "$staged" | grep -E '(^|/)\.env$|(^|/)\.env\.local$|(^|/)\.env\.[^/]+\.local$|credentials\.json|\.pem$|id_rsa' || true
  exit 1
fi

echo "→ lint-staged（oxlint + oxfmt）"
pnpm exec lint-staged || exit 1

# 类型检查覆盖整个项目；仅改文档 / 纯配置时可跳过以加快提交
if echo "$staged" | grep -E '\.(ts|tsx|mts|cts|js|jsx|mjs|cjs)$|(^|/)tsconfig.*\.json$' >/dev/null 2>&1; then
  echo "→ typecheck"
  pnpm typecheck || exit 1
fi

echo "→ lint（全量，deny-warnings）"
pnpm lint || exit 1

echo "→ format:check"
pnpm format:check || exit 1

echo "✅ pre-commit 校验通过"
