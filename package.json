{
  "name": "aii-next",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "theme:sync": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/generate-antd-tailwind-theme.ts",
    "dev": "pnpm theme:sync && vite",
    "build": "pnpm theme:sync && tsc -b && vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "lint": "oxlint --deny-warnings .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "validate": "pnpm typecheck && pnpm lint && pnpm format:check",
    "swagger-g": "pnpm exec swagger-to-ts generate -c api.swagger.config.ts",
    "lint:commit": "commitlint --from HEAD~1 --to HEAD --verbose",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxlint --fix --deny-warnings",
      "oxfmt"
    ],
    "*.{json,css,scss,less,md,mdx,yaml,yml,html}": "oxfmt"
  },
  "dependencies": {
    "@asiainfo/auth": "git+http://10.21.1.109/openbilling/frontend-component-library.git#v0.1.0&path:asiainfo-auth",
    "@icon-park/react": "^1.4.2",
    "@tanstack/react-router": "^1.170.17",
    "antd": "^6.5.0",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "keycloak-js": "^26.2.4",
    "lodash-es": "^4.18.1",
    "motion": "^12.42.2",
    "nprogress": "^0.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "swagger-to-ts-axios": "^2.2.2",
    "yaml": "^2.9.0",
    "zustand": "^5.0.14"
  },
  "dependenciesMeta": {},
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.1",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.3"
  }
}
