{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "unicorn", "oxc", "import", "jsx-a11y", "promise"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "es2022": true
  },
  "ignorePatterns": ["dist", "src/routeTree.gen.ts", "src/api/"],
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/rules-of-hooks": "error",
    "react/exhaustive-deps": "error",
    "react/only-export-components": [
      "error",
      {
        "allowConstantExport": true
      }
    ],
    "react/jsx-key": "error",
    "react/jsx-no-duplicate-props": "error",
    "react/jsx-no-undef": "error",
    "react/no-children-prop": "error",
    "react/no-danger-with-children": "error",
    "react/no-direct-mutation-state": "error",
    "react/no-string-refs": "error",
    "react/jsx-props-no-spreading": "off",
    "react/jsx-max-depth": "off",
    "react/button-has-type": "error",

    "typescript/no-explicit-any": "error",
    "typescript/ban-ts-comment": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/consistent-type-definitions": "off",

    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "prefer-const": "error",
    "no-var": "error",
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "no-debugger": "error",
    "no-alert": "error",

    "max-lines-per-function": "off",
    "max-lines": "off",
    "max-statements": "off",
    "max-params": "off",
    "max-depth": "off",
    "no-magic-numbers": "off",
    "id-length": "off",
    "sort-keys": "off",
    "sort-imports": "off",
    "func-style": "off",
    "no-ternary": "off",
    "curly": "off",
    "capitalized-comments": "off",
    "no-underscore-dangle": "off",
    "no-continue": "off",
    "no-negated-condition": "off",
    "prefer-destructuring": "off",
    "prefer-named-capture-group": "off",
    "require-unicode-regexp": "off",
    "no-shadow": "off",

    "unicorn/no-null": "off",
    "unicorn/prefer-global-this": "off",
    "unicorn/filename-case": "off",
    "unicorn/no-array-for-each": "off",
    "unicorn/no-useless-undefined": "off",
    "unicorn/prefer-ternary": "off",
    "unicorn/no-negated-condition": "off",
    "unicorn/no-array-callback-reference": "off",
    "unicorn/no-array-sort": "off",
    "unicorn/no-immediate-mutation": "off",
    "unicorn/prefer-single-call": "off",
    "unicorn/prefer-string-replace-all": "off",
    "unicorn/prefer-export-from": "off",
    "unicorn/max-nested-calls": "off",
    "unicorn/no-nested-ternary": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/prefer-query-selector": "off",
    "unicorn/require-module-specifiers": "off",
    "unicorn/no-abusive-eslint-disable": "error",

    "import/no-named-export": "off",
    "import/group-exports": "off",
    "import/prefer-default-export": "off",
    "import/exports-last": "off",
    "import/max-dependencies": "off",
    "import/no-unassigned-import": "off",
    "import/consistent-type-specifier-style": "off",
    "import/no-nodejs-modules": "off",
    "import/no-named-as-default-member": "off",
    "import/no-duplicates": "error",
    "no-duplicate-imports": "off"
  },
  "overrides": [
    {
      "files": ["src/routes/**/*.{ts,tsx}", "src/components/AIITable/index.tsx"],
      "rules": {
        "react/only-export-components": "off"
      }
    },
    {
      "files": ["scripts/**/*.{ts,js,mjs,cjs}", "*.config.{ts,js,mjs,cjs}", "src/theme/generate-antd-tokens-css.ts"],
      "env": {
        "node": true
      },
      "rules": {
        "no-console": "off"
      }
    }
  ]
}
